# API 키 및 인증
*.json
!config/*.yaml
config/youtube_token.pickle
client_secret*.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 로그
*.log
logs/

# 테스트
test_*.mp4
test_*.mp3
